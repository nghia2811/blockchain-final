# -------------------------------------------------------
# RPC endpoint (Infura / Alchemy / local Anvil fork)
# -------------------------------------------------------
RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY
# For local Anvil fork:
# RPC_URL=http://127.0.0.1:8545

# -------------------------------------------------------
# Deployed contract address (update after forge deploy)
# -------------------------------------------------------
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS

# -------------------------------------------------------
# Chainlink Price Feed addresses (mainnet)
# WETH/WBTC/USDC/LINK/UNI feeds are used by the token registry.
# -------------------------------------------------------
CHAINLINK_ETH_USD=0x5f4eC3Df9cbd43714FE2740f5E3616155c5b8419
CHAINLINK_BTC_USD=0xF4030086522a5bEEa4988F8cA5B36dbC97BeE88c
CHAINLINK_USDC_USD=0x8fFfFfd4AfB6115b954Bd326cbe7B4BA576818f6
CHAINLINK_LINK_USD=0x2c1d072e956AFFC0D435Cb7AC38EF18d24d9127c
CHAINLINK_UNI_USD=0x553303d460EE0afB37EdFf9bE42922D8FF63220e

# Sepolia feeds (uncomment when testing on Sepolia):
# CHAINLINK_ETH_USD=0x694AA1769357215DE4FAC081bf1f309aDC325306
# CHAINLINK_BTC_USD=0x1b44F3514812d835EB1BDB0acB33d3fA3351Ee43

# -------------------------------------------------------
# Protocol addresses
# -------------------------------------------------------
UNISWAP_V3_ROUTER=0xE592427A0AEce92De3Edee1F18E0157C05861564
COMPOUND_V3_USDC=0xc3d688B66703497DAA19211EEdff47f25384cdc3
AAVE_V3_POOL=0x87870Bca3F3fD6335C3F4ce8392D69350B4fA4E2

# -------------------------------------------------------
# Token addresses (mainnet) — used by the TOKENS registry
# -------------------------------------------------------
WETH=0xC02aaA39b223FE8D0A0e5C4F27eAD9083C756Cc2
WBTC=0x2260FAC5E5542a773Aa44fBCfeDf7C193bc2C599
USDC=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
LINK=0x514910771AF9Ca656af840dff83E8264EcF986CA
UNI=0x1f9840a85d5aF5bf1D1762F925BDADdC4201F984

# -------------------------------------------------------
# Uniswap V3 pool addresses (mainnet)
# -------------------------------------------------------
POOL_WETH_USDC=0x88e6A0c2dDD26FEEb64F039a2c41296FcB3f5640
POOL_WETH_WBTC=0xCBCdF9626bC03E24f779434178A73a0B4bad62eD
POOL_WBTC_USDC=0x99ac8cA7087fA4A2A1FB6357269965A2014ABc35
POOL_LINK_WETH=0xa6Cc3C2531FdaA6Ae1A3CA84c2855806728693e8
POOL_UNI_WETH=0x1d42064Fc4Beb5F8aAF85F4617AE8b3b5B8Bd801

# -------------------------------------------------------
# Strategy thresholds
# -------------------------------------------------------
ARBITRAGE_MIN_SPREAD_PCT=0.3
LENDING_MIN_APY_PCT=1.0
PRICE_STALE_SECONDS=3600

# -------------------------------------------------------
# Advanced: add extra tokens at runtime (JSON)
# Example adds AAVE token with its Chainlink USD feed:
# EXTRA_TOKENS_JSON={"AAVE":{"address":"0x7Fc66500c84A76Ad7e9c93437bFc5Ac33E2DDaE9","decimals":18,"chainlink_usd":"0x547a514d5e3769680Ce22B2361c10Ea13619e8a9","default_amount":"1000000000000000000"}}
# -------------------------------------------------------
# EXTRA_TOKENS_JSON=

# -------------------------------------------------------
# Advanced: override arbitrage pairs at runtime (JSON array)
# Example replaces the default pairs with a single pair:
# ARBITRAGE_PAIRS_JSON=[{"token0":"WETH","token1":"USDC","pool_address":"0x88e6A0c2dDD26FEEb64F039a2c41296FcB3f5640","fee":500}]
# -------------------------------------------------------
# ARBITRAGE_PAIRS_JSON=
