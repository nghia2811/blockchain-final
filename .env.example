# Private key for deployment (without 0x prefix or with 0x prefix both work)
PRIVATE_KEY=your_private_key_here

# RPC URLs
MAINNET_RPC_URL=https://mainnet.infura.io/v3/your_key
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_key

# Admin addresses (optional - defaults to Anvil test accounts)
ADMIN1=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
ADMIN2=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
ADMIN3=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC

# Etherscan API key for verification
ETHERSCAN_API_KEY=your_etherscan_api_key
